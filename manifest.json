{
  "manifest_version": 3,
  "name": "Autodarts Modules",
  "version": "0.1.318",
  "icons": {
    "16": "Main/assets/ICON.png",
    "32": "Main/assets/ICON.png",
    "48": "Main/assets/ICON.png",
    "128": "Main/assets/ICON.png"
  },
  "permissions": ["storage", "scripting", "tabs", "sidePanel", "windows", "debugger"],
  "optional_permissions": ["camera", "microphone"],
  "description": "Autodarts modules with Streamer.bot integration and overlay tooling.",
  "host_permissions": [
    "https://play.autodarts.io/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "Main/core/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://play.autodarts.io/*"],
      "js": [
        "Main/bridge/content.js",
        "Modules/macros/content.js",
        "Modules/lobbyfilter/content.js",
        "Modules/themes/Horizontal/config.js",
        "Modules/themes/Vertical/config.js",
        "Modules/themes/Horizontal/library.js",
        "Modules/themes/Vertical/library.js",
        "Modules/themes/community-designs.js",
        "Modules/themes/content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_icon": {
      "16": "Main/assets/ICON.png",
      "32": "Main/assets/ICON.png"
    },
    "default_title": "Autodarts Modules"
  },
  "side_panel": {
    "default_path": "Main/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "Main/bridge/pageScript.js",
        "Main/settings/settings.ini"
      ],
      "matches": ["https://play.autodarts.io/*"]
    }
  ]
}
